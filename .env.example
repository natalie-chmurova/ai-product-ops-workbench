# Copy this file to ".env" and fill in your keys.

# Required — your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enables the "Send to ClickUp" button.
# Token: ClickUp → Settings → Apps → API Token (starts with pk_)
CLICKUP_API_TOKEN=pk_...
# The list tasks are created in, and the workspace id (for the board link).
CLICKUP_LIST_ID=
CLICKUP_TEAM_ID=

# Optional — map extracted owner names to ClickUp user ids (Name:id,Name:id)
OWNER_ALIASES=
